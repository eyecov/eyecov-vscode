{
  "name": "eyecov-vscode",
  "displayName": "EyeCov",
  "description": "Display code coverage in VS Code editor",
  "version": "0.2.29",
  "publisher": "eyecov",
  "license": "MIT",
  "icon": "images/eyecov-logo-256.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/eyecov/eyecov-vscode.git"
  },
  "engines": {
    "vscode": "^1.105.0",
    "node": ">=20"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "coverage",
    "testing",
    "phpunit",
    "eyecov"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "eyecov.builtin",
        "label": "EyeCov Built-in MCP Server"
      }
    ],
    "commands": [
      {
        "command": "eyecov.showCoverage",
        "title": "Show Coverage"
      },
      {
        "command": "eyecov.hideCoverage",
        "title": "Hide Coverage"
      },
      {
        "command": "eyecov.toggleCoverage",
        "title": "Toggle Coverage"
      },
      {
        "command": "eyecov.showCoverageInfo",
        "title": "Show Coverage Info"
      },
      {
        "command": "eyecov.rereadCoverage",
        "title": "Re-read Coverage"
      },
      {
        "command": "eyecov.showDebugOutput",
        "title": "Show Debug Output"
      },
      {
        "command": "eyecov.toggleGutterCoverage",
        "title": "Toggle Gutter Coverage"
      },
      {
        "command": "eyecov.toggleLineCoverage",
        "title": "Toggle Line Coverage"
      },
      {
        "command": "eyecov.toggleTrackCoverageThroughEdits",
        "title": "Toggle Track Coverage Through Edits"
      }
    ],
    "configuration": {
      "title": "EyeCov",
      "properties": {
        "eyecov.debug": {
          "type": "boolean",
          "default": false,
          "description": "When true, write debug logs to the EyeCov output channel (View → Output → EyeCov)."
        },
        "eyecov.showCoverageOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically show coverage when files are opened"
        },
        "eyecov.showUncovered": {
          "type": "boolean",
          "default": true,
          "description": "Highlight uncovered lines"
        },
        "eyecov.showCovered": {
          "type": "boolean",
          "default": true,
          "description": "Highlight covered lines"
        },
        "eyecov.showLineCoverage": {
          "type": "boolean",
          "default": true,
          "description": "Show coverage by changing background color of lines (default: true)"
        },
        "eyecov.showGutterCoverage": {
          "type": "boolean",
          "default": true,
          "description": "Show coverage with gutter icons in addition to background colors"
        },
        "eyecov.enableMcpServer": {
          "type": "boolean",
          "default": true,
          "description": "When true, register the built-in MCP server so AI hosts can query coverage (coverage_file, coverage_path, coverage_project). Set to false to disable."
        },
        "eyecov.prewarmCoverageCache": {
          "type": "boolean",
          "default": true,
          "description": "When true, runs a low-priority background crawl on startup to pre-index coverage for faster path/project queries."
        },
        "eyecov.trackCoverageThroughEdits": {
          "type": "boolean",
          "default": true,
          "description": "When true, coverage line numbers are shifted in memory when you insert or delete lines, so highlighting stays aligned. When false, coverage is not tracked through edits; after editing, use coverage refresh or reopen the file to realign."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run lint && npm run format:check && npm run typecheck && node ./scripts/build.mjs",
    "watch": "node ./scripts/build.mjs --watch",
    "report": "node ./out/report.js",
    "report:json": "node ./out/report.js --json",
    "report:verify": "node ./out/report.js --verify-report-totals",
    "typecheck": "tsc -p ./ --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --coverage",
    "test:no-coverage": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "report:from-vitest-lcov": "npm run test:coverage && node ./out/report.js --path coverage/lcov.info --workspace-root . --format lcov --sample-files 15",
    "test:mcp": "node scripts/verify-mcp-server.mjs",
    "compile:tests": "tsc -p tsconfig.test.json",
    "compile:all": "npm run compile && npm run compile:tests",
    "test:extension": "npm run compile:all && vscode-test",
    "package": "vsce package",
    "export:zip": "git archive --format=zip --prefix=eyecov-vscode/ -o eyecov-vscode.zip HEAD"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.105.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.0",
    "esbuild": "^0.27.4",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.18.0",
    "vsce": "^2.15.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  }
}
